# ─────────────────────────────────────────────────────────────────────────────
# Feenix AdTech — environment configuration
# Copy this file to `.env.local` for local development, and set the same vars
# in the Railway dashboard for production. NEVER commit a filled-in .env file.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable / anon key (safe to expose to the browser; RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — SERVER ONLY. Bypasses RLS. Used for admin actions
# (approving users, role changes) and the seed script. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret that Roblox game servers send in the `x-api-key` header when
# POSTing analytics to /api/ingest. Generate a long random string.
INGEST_API_KEY=

# Default password for the seeded `FEENIX` admin account (used by `npm run seed`).
# Change this before deploying to production.
ADMIN_DEFAULT_PASSWORD=feenixgroup0214
